                            <th class="p-5 font-semibold">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/50">
                        <tr v-if="isLoading">
                            <td colspan="6" class="p-10 text-center text-slate-500">Connecting to API Gateway...</td>
                        </tr>
                        <tr v-for="user in customers" :key="user._id" class="group transition-all duration-300 hover:bg-slate-800/50">
                            <td class="p-5 font-mono text-sm text-cyan-400">{{ user.id || 'N/A' }}</td>
                            <td class="p-5 text-slate-200">{{ user.name || user.fullName || 'N/A' }}</td>
                            <td class="p-5 text-sm text-slate-400">{{ user.email || 'N/A' }}</td>
                            <td class="p-5 font-mono text-sm text-slate-300">{{ user.age || 'N/A' }}</td>
                            <td class="p-5 font-mono text-emerald-400">
                                <span v-if="user.moneySpent !== undefined || user.totalSale !== undefined">
                                    ${{ formatCurrency(user.moneySpent || user.totalSale || 0) }}
                                </span>
                                <span v-else class="text-rose-500">N/A</span>
                            </td>
                            <td class="p-5">
                                <button @click="editCustomer(user)" class="text-xs bg-slate-700 hover:bg-slate-600 text-white px-3 py-1 rounded transition-colors">Edit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <script src="./js/app.js"></script>
</body>
</html>
</file>

